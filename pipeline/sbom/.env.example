# =============================================================================
# .env.example — copy this file to .env and fill in your values.
# NEVER commit the real .env file to git.
# =============================================================================

# Your GitHub Personal Access Token.
# Classic PAT:      needs 'repo' scope for private repos (or no scope for public).
# Fine-grained PAT: needs 'dependency_graph: read' permission.
# Create one at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# Repository owner (GitHub username or organization name)
GITHUB_OWNER=Sreys54

# Repository name
GITHUB_REPO=CursoKmpApp-GitGraph

# (Optional) Where to save the SBOM file. Defaults to sbom.json
# SBOM_OUTPUT_PATH=sbom.json
